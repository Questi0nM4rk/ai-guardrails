# Suppression allowlist for ai-guardrails
#
# Format: one Python regex per non-comment line.
# Each pattern is matched against "{filepath}:{lineno}:{line_content}".
# Every entry must document WHY it is legitimate.
#
# Approval required: human must review and approve any additions here.
# Do not add entries to silence false positives — fix the code instead.

# ---------------------------------------------------------------------------
# constants.py — string DATA containing suppression pattern strings
# These lines are tuple entries in SUPPRESSION_PATTERNS, not actual suppressions.
# The strings "# noqa", "# type: ignore" etc. are pattern VALUES being registered.
# ---------------------------------------------------------------------------
constants\.py:\d+:\s+\(r"#\s*noqa
constants\.py:\d+:\s+\(r"#\s*type: ignore
constants\.py:\d+:\s+\(r"#\s*pylint:
constants\.py:\d+:\s+\(r"#\s*pragma: no cover

# ---------------------------------------------------------------------------
# infra/command_runner.py
# S603: CommandRunner is the single subprocess abstraction — it is the intended
# call site for subprocess.run with variable args. All other code uses CommandRunner.
# ---------------------------------------------------------------------------
infra/command_runner\.py:\d+:.*subprocess\.run.*# noqa: S603

# ---------------------------------------------------------------------------
# hooks/config_ignore.py
# subprocess.run calls git — trusted, controlled input, this IS a pre-commit hook.
# PLR0915: main() orchestrates several sequential steps; splitting would obscure flow.
# ---------------------------------------------------------------------------
hooks/config_ignore\.py:\d+:.*subprocess\.run.*# noqa: S603
hooks/config_ignore\.py:\d+:.*\["git".*# noqa: S607
hooks/config_ignore\.py:\d+:def main.*# noqa: PLR0915

# ---------------------------------------------------------------------------
# hooks/suppress_comments.py
# PLR0911: _infer_extension has many early returns by design (extension detection).
# ---------------------------------------------------------------------------
hooks/suppress_comments\.py:\d+:def _infer_extension.*# noqa: PLR0911

# ---------------------------------------------------------------------------
# hooks/protect_configs.py
# PLR0911: check_tool_input has many early returns by design (multi-condition guard).
# ---------------------------------------------------------------------------
hooks/protect_configs\.py:\d+:def check_tool_input.*# noqa: PLR0911

# ---------------------------------------------------------------------------
# languages/_base.py
# TC003: Path is imported at runtime — used in BaseLanguagePlugin.detect() glob() calls
#        and as a Protocol method parameter (runtime_checkable Protocol needs it).
# ARG002: Base class stub implementations intentionally ignore all parameters;
#         subclasses override with real implementations.
# ---------------------------------------------------------------------------
languages/_base\.py:\d+:from pathlib import Path.*# noqa: TC003
languages/_base\.py:\d+:.*# noqa: ARG002

# ---------------------------------------------------------------------------
# languages/python.py
# type: ignore[no-redef]: tomllib is in stdlib on Python 3.11+ and in tomli on 3.10.
# The import guard pattern triggers no-redef because both branches define the same name.
# ---------------------------------------------------------------------------
languages/python\.py:\d+:import tomllib.*# type: ignore\[no-redef\]

# ---------------------------------------------------------------------------
# languages/_registry.py
# BLE001: Loading arbitrary user-provided plugin modules requires broad Exception catch.
# User plugins can raise literally any exception on import or instantiation.
# The exception is logged with exc_info=True before being swallowed.
# ---------------------------------------------------------------------------
languages/_registry\.py:\d+:.*# noqa: BLE001

# ---------------------------------------------------------------------------
# tests/ — type: ignore in test files
# [misc]: Assigning to a frozen dataclass field in pytest.raises(AttributeError)
#   blocks. Mypy sees this as a type error; we need the statement to exist at
#   runtime so pytest can assert it raises. Not a real suppression — the test
#   is verifying that the assignment fails.
# [arg-type]: Passing deliberately wrong types (invalid Literals, **dict with
#   mixed types) to test runtime validation or exercise all code paths.
#   These are intentional bad-type probes, not production code suppressions.
# ---------------------------------------------------------------------------
tests/.*\.py:\d+:.*# type: ignore\[misc\]
tests/.*\.py:\d+:.*# type: ignore\[arg-type\]

# ---------------------------------------------------------------------------
# generators/agent_rules.py
# ARG002: AgentRulesGenerator.generate() and .check() satisfy the Generator
#         protocol which requires registry/languages/project_dir parameters.
#         The generator is template-driven and does not use these args directly,
#         but the protocol signature cannot be changed.
# ---------------------------------------------------------------------------
generators/agent_rules\.py:\d+:.*# noqa: ARG002

# ---------------------------------------------------------------------------
# generators/ruff.py, generators/markdownlint.py, generators/editorconfig.py,
# generators/lefthook.py
# ARG002: Generator protocol requires (registry, languages, project_dir) on
#         generate() and (registry, project_dir) on check(). Some generators
#         do not use all parameters but must match the protocol signature.
# ---------------------------------------------------------------------------
generators/ruff\.py:\d+:.*# noqa: ARG002
generators/markdownlint\.py:\d+:.*# noqa: ARG002
generators/editorconfig\.py:\d+:.*# noqa: ARG002
generators/lefthook\.py:\d+:.*# noqa: ARG002

# ---------------------------------------------------------------------------
# pipelines/init_pipeline.py
# PLR0913: InitPipeline.__init__ must accept all pipeline config paths as
#          explicit constructor args (data_dir, configs_dir, registry_template,
#          ci_template, agent_template, custom_plugins_dir) for testability.
#          Bundling into a config dataclass would hide required dependencies.
# ---------------------------------------------------------------------------
pipelines/init_pipeline\.py:\d+:\s*def __init__.*# noqa: PLR0913
